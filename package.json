{
  "name": "aihub",
  "version": "0.1.0",
  "description": "Interactive launcher for AI coding CLIs — Claude Code, OpenAI Codex, Gemini CLI.",
  "type": "module",
  "bin": {
    "aihub": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "bun run src/index.tsx",
    "start": "bun run dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-big-text": "^2.0.0",
    "ink-gradient": "^3.0.0",
    "ink-select-input": "^6.0.0",
    "ink-spinner": "^5.0.0",
    "react": "^18.3.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "^18.3.12",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  },
  "keywords": [
    "cli",
    "ai",
    "claude-code",
    "codex",
    "gemini",
    "launcher",
    "ink",
    "bun"
  ]
}
